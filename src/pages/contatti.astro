---
import Base from '../layouts/Base.astro';
---

<Base title="Contatti" description="Contatta Martino Pirella per consulenza AI governance.">
  <section class="hero hero-image" style="background-image: url('/images/chatgpt-image-20-feb-2026-13_42_53.webp');">
    <div class="hero-content">
      <p class="eyebrow">Contatti</p>
      <h1>Come contattarmi</h1>
    </div>
  </section>

  <section class="section">
    <div class="wrap" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl);">
      <div>
        <div class="card" style="margin-bottom: var(--space-lg);">
          <h3>Email</h3>
          <p><a href="mailto:mpirella@gmail.com">mpirella@gmail.com</a></p>
        </div>
        <div class="card" style="margin-bottom: var(--space-lg);">
          <h3>LinkedIn</h3>
          <p><a href="https://www.linkedin.com/in/martino-pirella/" target="_blank" rel="noopener">linkedin.com/in/martino-pirella</a></p>
        </div>
        <p style="color: var(--muted); font-size: 0.9rem;">Non faccio spam, non cedo dati a terzi. Se mi scrivi, ti rispondo io.</p>
      </div>
      <div>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="card">
          <div class="form-group">
            <label for="name">Nome</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="message">Messaggio</label>
            <textarea id="message" name="message"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Invia messaggio</button>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  @media (max-width: 768px) {
    .wrap[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
