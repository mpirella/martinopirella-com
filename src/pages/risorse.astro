---
import Base from '../layouts/Base.astro';

const risorse = [
  {
    title: "Amplification Risk Matrix",
    image: "/images/unnamed-29.webp",
    url: "https://amplification.martinopirella.com/",
    desc: "C'è un'illusione pericolosa nelle aziende: pensare che l'Intelligenza Artificiale possa \"aggiustare\" un processo che non funziona. Non è vero. La realtà è brutale: l'IA amplifica lo stato attuale. Ho sviluppato la Amplification Risk Matrix per poterlo verificare."
  },
  {
    title: "Mappa Globale dell'AI per Settore — 2026",
    image: "/images/mappa-ai-settori.webp",
    url: "/tools/mappa-ai-settori.html",
    desc: "Una ricognizione critica dei livelli di adozione, impatto e rischio dell'intelligenza artificiale nei principali settori economici, sociali e militari. Dati verificati, maggio 2026."
  },
  {
    title: "VAC — Valutazione dell'Autonomia Cognitiva",
    image: "/images/autonomia.webp",
    url: "/tools/vac.html",
    desc: "Quanto sei ancora in grado di pensare in modo indipendente dall'AI? La VAC misura 7 dimensioni critiche della tua autonomia cognitiva come supervisore di sistemi AI. 21 domande, 15–20 minuti."
  },
  {
    title: "Protocollo Conrad — Audit della Deriva Cognitiva",
    image: "/images/puntonave.webp",
    url: "/tools/protocollo-conrad.html",
    desc: "Questo strumento non valuta l'AI, ma la tua relazione con essa. Tre fasi — Mappatura, Bonaccia e Linea d'Ombra — per capire se la comodità si è trasformata in dipendenza."
  }
];
---

<Base title="Risorse" description="Strumenti e risorse per l'AI governance.">
  <section class="hero hero-image" style="background-image: url('/images/4bbbab46-ab80-4fe3-97b3-eb9c9154a724.webp');">
    <div class="hero-content">
      <p class="eyebrow">Strumenti</p>
      <h1>Risorse</h1>
      <p style="font-size: 1.15rem; color: rgba(245,240,232,0.65); max-width: 600px;">Strumenti, framework e risorse operative per l'AI governance.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {risorse.map(r => (
        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: var(--space-xl); align-items: center; margin-bottom: var(--space-xl);">
          <a href={r.url} target="_blank" rel="noopener noreferrer">
            <img src={r.image} alt={r.title} style="border-radius: var(--radius-lg); box-shadow: var(--shadow-md);" />
          </a>
          <div>
            <h2><a href={r.url} target="_blank" rel="noopener noreferrer">{r.title}</a></h2>
            <p style="color: var(--slate); margin-top: var(--space-sm);">{r.desc}</p>
            <a href={r.url} target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="margin-top: var(--space-md);">Apri lo strumento →</a>
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  @media (max-width: 768px) {
    div[style*="grid-template-columns: 1fr 2fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
