---
import Base from '../layouts/Base.astro';
---

<Base title="Il tuo profilo AI" description="Sedici domande per scoprire il tuo profilo nell'uso dell'intelligenza artificiale.">
  <div class="tool-embed">
    <iframe src="/tools/profilo-ai.html" title="Il tuo profilo AI"></iframe>
  </div>
</Base>

<style>
  .tool-embed {
    margin-top: 72px;
  }
  .tool-embed iframe {
    width: 100%;
    min-height: calc(100vh - 72px);
    border: none;
    display: block;
  }
</style>

<script>
  const iframe = document.querySelector('.tool-embed iframe');
  if (iframe) {
    iframe.addEventListener('load', () => {
      try {
        const h = iframe.contentDocument?.documentElement?.scrollHeight;
        if (h) iframe.style.height = h + 'px';
      } catch(e) {}
    });
  }
</script>
